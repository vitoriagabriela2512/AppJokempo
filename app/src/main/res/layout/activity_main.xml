<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp"
    android:background="#FFF3E0"
    tools:context=".MainActivity">
    

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JOKENPO"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#6A1B9A"
        android:layout_marginBottom="20dp" />



    <ImageView
        android:id="@+id/imgApp"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/padrao"
        android:layout_marginBottom="20dp" />



    <TextView
        android:id="@+id/txtResultado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escolha uma opção"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="20dp" />



    <TextView
        android:id="@+id/txtPlacar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jogador: 0 | App: 0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#4E342E"
        android:layout_marginBottom="25dp" />



    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">


        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/img"
            android:onClick="selecionadoPedra"
            android:layout_margin="10dp" />



        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/papel"
            android:onClick="selecionadoPapel"
            android:layout_margin="10dp" />



        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/tesoura"
            android:onClick="selecionadoTesoura"
            android:layout_margin="10dp" />

    </LinearLayout>


    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reiniciar"
        android:textSize="18sp"
        android:backgroundTint="#8E24AA"
        android:textColor="#FFFFFF"
        android:layout_marginTop="30dp"
        android:onClick="reiniciarJogo"/>

</LinearLayout>